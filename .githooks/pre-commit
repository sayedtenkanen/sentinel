#!/usr/bin/env python3
"""
Pre-commit hook — runs ruff lint/format, ty type check, secrets scan, and coverage.

Install:  git config core.hooksPath .githooks
Skip:     SKIP=lint,format,ty,secrets,coverage git commit
"""

import importlib
import os
import sys

HOOK_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_DIR = os.path.dirname(HOOK_DIR)
SKIP = os.environ.get("SKIP", "").split(",")


def _call_module(mod_name, args):
    old_argv = sys.argv
    old_cwd = os.getcwd()
    os.chdir(PROJECT_DIR)
    sys.argv = [mod_name] + args
    try:
        mod = importlib.import_module(mod_name)
        if hasattr(mod, "main"):
            mod.main()
        return 0
    except SystemExit as e:
        return e.code if isinstance(e.code, int) else 1
    finally:
        sys.argv = old_argv
        os.chdir(old_cwd)


def _call_module_with_output(mod_name, args):
    from io import StringIO

    old_stdout = sys.stdout
    old_stderr = sys.stderr
    old_argv = sys.argv
    old_cwd = os.getcwd()
    sys.stdout = StringIO()
    sys.stderr = StringIO()
    os.chdir(PROJECT_DIR)
    sys.argv = [mod_name] + args
    try:
        mod = importlib.import_module(mod_name)
        if hasattr(mod, "main"):
            mod.main()
        return type("_R", (), {
            "returncode": 0,
            "stdout": sys.stdout.getvalue(),
            "stderr": sys.stderr.getvalue(),
        })()
    except SystemExit as e:
        return type("_R", (), {
            "returncode": e.code if isinstance(e.code, int) else 1,
            "stdout": sys.stdout.getvalue(),
            "stderr": sys.stderr.getvalue(),
        })()
    finally:
        sys.stdout = old_stdout
        sys.stderr = old_stderr
        sys.argv = old_argv
        os.chdir(old_cwd)


def get_staged_python_files():
    import subprocess

    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        capture_output=True, text=True,
        cwd=os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
    )
    files = [f for f in result.stdout.strip().split("\n") if f]
    return [f for f in files if f.endswith(".py") and os.path.exists(f)]


def run_ruff_lint():
    if "lint" in SKIP:
        print("⏭️  SKIP=lint — skipping ruff lint")
        return True

    result = _call_module_with_output("ruff", ["check", "sentinel/", "tests/"])
    if result.returncode != 0:
        print("🔴 RUFF LINT FAILED:")
        print(result.stdout or result.stderr)
        return False

    print("✅ Ruff lint passed")
    return True


def run_ruff_format():
    if "format" in SKIP:
        print("⏭️  SKIP=format — skipping ruff format")
        return True

    result = _call_module_with_output("ruff", ["format", "--check", "sentinel/", "tests/"])
    if result.returncode != 0:
        print("🔴 RUFF FORMAT FAILED:")
        print(result.stdout or result.stderr)
        return False

    print("✅ Ruff format passed")
    return True


def run_ty_check():
    if "ty" in SKIP:
        print("⏭️  SKIP=ty — skipping type check")
        return True

    result = _call_module_with_output("ty", ["check", "sentinel/"])
    if result.returncode != 0:
        print("🔴 TY TYPE CHECK FAILED:")
        print(result.stdout or result.stderr)
        return False

    print("✅ Ty type check passed")
    return True


def run_secrets_scan(files):
    if "secrets" in SKIP:
        print("⏭️  SKIP=secrets — skipping secrets scan")
        return True

    if not files:
        return True

    non_test_files = [f for f in files if not f.startswith("tests/")]
    if not non_test_files:
        print("✅ Secrets scan skipped (only test files)")
        return True

    from sentinel.tools.secrets_scanner import main as scanner_main

    old_stdout = sys.stdout
    sys.stdout = __import__("io").StringIO()
    try:
        scanner_main(non_test_files)
        output = sys.stdout.getvalue()
        if "No secrets detected" not in output and output.strip():
            print("🔴 SECRETS SCAN FAILED:")
            print(output)
            return False
        print("✅ Secrets scan passed")
        return True
    except SystemExit:
        output = sys.stdout.getvalue()
        if "No secrets detected" not in output and output.strip():
            print("🔴 SECRETS SCAN FAILED:")
            print(output)
            return False
        print("✅ Secrets scan passed")
        return True
    finally:
        sys.stdout = old_stdout


def run_coverage_check(files):
    if "coverage" in SKIP:
        print("⏭️  SKIP=coverage — skipping coverage check")
        return True

    if not files:
        return True

    try:
        import coverage
    except ImportError:
        print("⚠️  coverage not installed — skipping coverage check")
        return True

    import unittest

    old_cwd = os.getcwd()
    os.chdir(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    try:
        loader = unittest.TestLoader()
        suite = loader.discover("tests/")
        runner = unittest.TextTestRunner(stream=open(os.devnull, "w"), verbosity=0)
        runner.run(suite)
    finally:
        os.chdir(old_cwd)

    cov = coverage.Coverage()
    cov.load()
    total = cov.report(file=open(os.devnull, "w"))
    cov.erase()

    threshold = 85.0
    if total < threshold:
        print(f"🔴 Coverage check: {total:.1f}% (threshold: {threshold}%)")
        print("   Run tests locally or add SKIP=coverage to bypass")
        return False

    print(f"✅ Coverage check: {total:.1f}% (threshold: {threshold}%)")
    return True


def main():
    staged = get_staged_python_files()

    if not run_ruff_lint():
        return 1

    if not run_ruff_format():
        return 1

    if not run_ty_check():
        return 1

    if staged:
        print(f"🔍 Checking {len(staged)} staged file(s) for secrets")

        if not run_secrets_scan(staged):
            return 1

        if not run_coverage_check(staged):
            return 1
    else:
        print("✅ No staged Python files — skipping file-level checks")

    return 0


if __name__ == "__main__":
    sys.exit(main())
